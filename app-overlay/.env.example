# Sample environment file for local development.
# In Kubernetes, these values come from the ConfigMap (non-sensitive)
# and Secret (APP_KEY, DB credentials, etc.). See helm/laravel-k8s/values.yaml.

APP_NAME="Laravel K8s"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# Default: SQLite. Switch to mysql/pgsql by overriding via env from K8s.
DB_CONNECTION=sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

# Redis (only used if QUEUE_CONNECTION=redis or CACHE_DRIVER=redis)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
