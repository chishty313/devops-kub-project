# =============================================================================
# .gitignore — devops-kub-project
# =============================================================================
# Goal: keep the repo a clean, reproducible source-of-truth. Anything that is
# (a) generated, (b) machine-specific, or (c) sensitive stays OUT.
# =============================================================================

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
.history/
.fleet/
.zed/
*.code-workspace
*.swp
*.swo
*~
.*.swp
.*.swo

# -----------------------------------------------------------------------------
# Shell / dev caches that creep into a working dir
# -----------------------------------------------------------------------------
.bash_history
.zsh_history
.python-history
.node_repl_history
.npm/
.yarn/
.pnpm-store/

# -----------------------------------------------------------------------------
# Laravel application (lives under src/, generated by composer create-project)
# -----------------------------------------------------------------------------
src/vendor/
src/node_modules/
src/.env
src/.env.*
!src/.env.example
src/.phpunit.result.cache
src/.phpunit.cache/
src/storage/*.key
src/storage/logs/*
src/storage/framework/cache/data/*
src/storage/framework/sessions/*
src/storage/framework/views/*
src/storage/framework/testing/*
src/bootstrap/cache/*.php
src/public/storage
src/public/hot

# Keep .gitkeep files so the empty storage tree survives a fresh clone
!src/storage/logs/.gitkeep
!src/storage/framework/cache/data/.gitkeep
!src/storage/framework/sessions/.gitkeep
!src/storage/framework/views/.gitkeep
!src/storage/framework/testing/.gitkeep
!src/bootstrap/cache/.gitkeep

# -----------------------------------------------------------------------------
# Secrets — nothing sensitive ever leaves the box
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.local.yaml
values.local.yaml
*.pem
*.key
*.crt
*.p12
*.pfx
*.kubeconfig
kubeconfig*
admin.conf
super-admin.conf

# -----------------------------------------------------------------------------
# Cluster / runtime files generated by our scripts on the VM
# -----------------------------------------------------------------------------
cluster.env                    # written by scripts/05-launch-multipass-vms.sh, contains node IPs
cluster-cloud-init.yaml        # generated cloud-init payload for multipass
*.join-command
kubeadm-join*.sh
multipass.log
calico-installation.yaml

# -----------------------------------------------------------------------------
# Build artefacts / packaged charts
# -----------------------------------------------------------------------------
*.log
*.tar
*.tar.gz
*.tgz
*.zip
dist/
build/
out/
coverage/
*.lcov
.nyc_output/

# Helm-rendered output / packaged chart bundles
helm/**/charts/
helm/**/Chart.lock
helm/**/*.tgz
chart-render.yaml
rendered.yaml

# -----------------------------------------------------------------------------
# Container build cache / scratch
# -----------------------------------------------------------------------------
.docker/
.buildx-cache/

# -----------------------------------------------------------------------------
# Project-local scratch / experiments
# -----------------------------------------------------------------------------
scratch/
tmp/
.tmp/
*.tmp
*.bak
*.orig
NOTES.local.md
TODO.local.md
